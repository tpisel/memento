# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/

# Local tool caches
.cache/

# Ralph loop run logs
logs/*
!logs/memento-fb0.9-*.log

# os cruft
.DS_Store

# Obsidian per-machine UI state
**/.obsidian/workspace*
**/.obsidian/cache/
**/.obsidian/.trash/
**/.obsidian/plugins/*/data.json

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# memento:gitignore:start
# Obsidian per-machine UI state
**/.obsidian/workspace*
**/.obsidian/cache
# Memento generated artifacts
**/_memento/brief.md
# Memento unlock grants (manifest and config beside it stay tracked)
**/.memento/unlock-grants.json
# Memento pending-write ledger (check-write↔compile drift handshake)
**/.memento/pending-writes.json
# Memento check-write decision log (enforcement audit)
**/.memento/decision-log.jsonl
# memento:gitignore:end

# goreleaser build output
dist/

# A-UAT probe transcripts (local evidence, regenerated per run)
scripts/a-uat/runs/
# A-UAT per-arm memento binaries, built from each arm's frozen commit
scripts/a-uat/.bin/
# Python bytecode cache from the scorer + its fixture tests
scripts/a-uat/__pycache__/

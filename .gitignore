# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/

# Local tool caches
.cache/

# Ralph loop run logs
logs/

# os cruft
.DS_Store

# Obsidian per-machine UI state
**/.obsidian/workspace*
**/.obsidian/cache/
**/.obsidian/.trash/
**/.obsidian/plugins/*/data.json

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# memento:gitignore:start
# Obsidian per-machine UI state
memento-memory/.obsidian/workspace*
memento-memory/.obsidian/cache
# Memento generated artifacts
memento-memory/_memento/brief.md
# memento:gitignore:end

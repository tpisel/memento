#!/bin/sh
set -eu

if [ -d /usr/local/go/bin ]; then
  PATH="/usr/local/go/bin:$PATH"
  export PATH
fi

usage() {
  cat <<'USAGE'
Usage: scripts/ralph-loop <agent> [bead-id]

Run Ralph agent iterations against this repository.

  <agent>     Required. Either 'codex' or 'claude'.
  [bead-id]   Optional. If given, run a single iteration on this bead.
              If omitted, iterate over ready non-epic beads until none
              remain or RALPH_MAX_ITERATIONS is reached.

Environment overrides:
  RALPH_MODEL             Model (defaults: codex=gpt-5.5, claude unset → CLI default)
  RALPH_REASONING_EFFORT  Codex reasoning effort (default: high)
  RALPH_SANDBOX           Codex sandbox (default: workspace-write)
  RALPH_APPROVAL_POLICY   Codex approval policy (default: never)
  RALPH_MAX_ITERATIONS    Cap on auto-mode iterations (default: 20)
  RALPH_DRY_RUN           If 1, print the agent command and prompt
USAGE
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  "")
    usage >&2
    exit 2
    ;;
esac

agent="$1"
shift

case "$agent" in
  codex|claude) ;;
  *)
    echo "scripts/ralph-loop: agent must be 'codex' or 'claude' (got '$agent')" >&2
    usage >&2
    exit 2
    ;;
esac

if [ "$#" -gt 1 ]; then
  usage >&2
  exit 2
fi

requested_bead="${1:-}"

if ! command -v "$agent" >/dev/null 2>&1; then
  echo "scripts/ralph-loop: $agent is not on PATH" >&2
  exit 127
fi

if ! command -v bd >/dev/null 2>&1; then
  echo "scripts/ralph-loop: bd is not on PATH" >&2
  exit 127
fi

repo="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$repo" ]; then
  echo "scripts/ralph-loop: must be run inside a git repository" >&2
  exit 1
fi

# Refuse to start with a dirty worktree.
# The wrapper commits via `git add -A` after each iteration, so any pre-existing
# modifications or untracked files would otherwise be swept into the next bead's
# commit — misattributing user WIP to whichever bead the loop happens to pick up.
if [ -n "$(git -C "$repo" status --porcelain)" ]; then
  echo "scripts/ralph-loop: refusing to start with a dirty worktree." >&2
  echo "Commit, stash, or clean these paths first:" >&2
  git -C "$repo" status --porcelain >&2
  exit 1
fi

GOCACHE="${GOCACHE:-/tmp/memento-go-build}"
GOMODCACHE="${GOMODCACHE:-$repo/.cache/go-mod}"
export GOCACHE GOMODCACHE

reasoning_effort="${RALPH_REASONING_EFFORT:-high}"
sandbox="${RALPH_SANDBOX:-workspace-write}"
approval_policy="${RALPH_APPROVAL_POLICY:-never}"
max_iterations="${RALPH_MAX_ITERATIONS:-20}"

case "$agent" in
  codex) model="${RALPH_MODEL:-gpt-5.5}" ;;
  claude) model="${RALPH_MODEL:-}" ;;
esac

current_bead=""

cleanup_comment() {
  code="$1"
  reason="$2"
  [ -z "$current_bead" ] && return 0
  bd comment "$current_bead" --stdin <<EOF >/dev/null 2>&1 || true
Ralph loop did not complete cleanly.

Reason: $reason
Exit code: $code

The bead may still be claimed or in progress. Inspect the worktree and bead state before resuming or resetting it.
EOF
}

trap 'cleanup_comment 130 "interrupted"; exit 130' INT
trap 'cleanup_comment 143 "terminated"; exit 143' TERM

next_ready_bead() {
  bd list --ready --exclude-type epic --flat --limit 1 | awk 'NR == 1 { print $2 }'
}

build_prompt() {
  bead_id="$1"
  cat <<EOF
You are running a Ralph loop for the memento repository.

Follow AGENTS.md exactly. This is a single-bead implementation loop.

Bead selection:
Use bead '$bead_id'. The Ralph wrapper has already claimed it. Do not select or claim a different bead. If this bead is invalid or blocked, add a bead comment and stop.

Loop contract:
1. Read AGENTS.md.
2. Inspect the selected bead with bd show.
3. Read linked durable context in memento-memory/ before editing.
4. Work only on the selected bead.
5. Prefer test-first development for deterministic core behavior.
6. Run the relevant verification commands.
7. If the bead is complete, close it with a concise note listing what changed and what was verified.
8. If the bead is not complete, add a bead comment with what was attempted, what blocked progress, useful task-scoped discoveries, and exact failing commands or errors.
9. If a discovery changes durable project understanding, update memento-memory/ in the same change set.

Commit handling:
The Ralph wrapper commits your bead's changes after you close it.
Do not run 'git add', 'git commit', 'git push', or any other git write commands.
You may read git state freely (git status, git diff, git log).
The agent sandbox blocks writes to .git/ anyway; attempts will fail.

Do not use built-in agent memories as a source of project truth.
EOF
}

run_agent() {
  prompt="$1"
  case "$agent" in
    codex)
      codex exec \
        --cd "$repo" \
        --ephemeral \
        --ignore-user-config \
        --disable memories \
        --sandbox "$sandbox" \
        --model "$model" \
        -c "model_reasoning_effort=\"$reasoning_effort\"" \
        -c "approval_policy=\"$approval_policy\"" \
        -c 'web_search="disabled"' \
        -c 'base_instructions=""' \
        "$prompt"
      ;;
    claude)
      if [ -n "$model" ]; then
        claude --print --dangerously-skip-permissions --model "$model" "$prompt"
      else
        claude --print --dangerously-skip-permissions "$prompt"
      fi
      ;;
  esac
}

print_dry_run() {
  prompt="$1"
  case "$agent" in
    codex)
      cat <<EOF
codex exec --cd "$repo" --ephemeral --ignore-user-config --disable memories --sandbox "$sandbox" --model "$model" -c model_reasoning_effort="$reasoning_effort" -c approval_policy="$approval_policy" -c web_search="disabled" -c base_instructions="" <prompt>

$prompt
EOF
      ;;
    claude)
      if [ -n "$model" ]; then
        cat <<EOF
claude --print --dangerously-skip-permissions --model "$model" <prompt>

$prompt
EOF
      else
        cat <<EOF
claude --print --dangerously-skip-permissions <prompt>

$prompt
EOF
      fi
      ;;
  esac
}

run_iteration() {
  bead_id="$1"
  current_bead="$bead_id"

  if [ "${RALPH_DRY_RUN:-0}" = "1" ]; then
    print_dry_run "$(build_prompt "$bead_id")"
    current_bead=""
    return 0
  fi

  bd update "$bead_id" --claim >/dev/null

  head_before="$(git -C "$repo" rev-parse HEAD)"

  set +e
  run_agent "$(build_prompt "$bead_id")"
  status=$?
  set -e

  if [ "$status" -ne 0 ]; then
    cleanup_comment "$status" "$agent exec exited non-zero"
    current_bead=""
    return "$status"
  fi

  head_after="$(git -C "$repo" rev-parse HEAD)"
  if [ "$head_before" != "$head_after" ]; then
    echo "scripts/ralph-loop: bead $bead_id was committed by the agent (unexpected; sandbox should block this)" >&2
    current_bead=""
    return 0
  fi

  # Agent didn't commit (expected — sandbox blocks .git writes). Wrapper commits.
  if git -C "$repo" diff --quiet HEAD && [ -z "$(git -C "$repo" ls-files --others --exclude-standard)" ]; then
    echo "scripts/ralph-loop: bead $bead_id closed with no working-tree changes; no commit needed" >&2
    current_bead=""
    return 0
  fi

  bead_title="$(bd show "$bead_id" 2>/dev/null \
    | awk 'NR==1 { sub(/^[^·]*· */, ""); sub(/[[:space:]]+\[.*$/, ""); print }')"
  [ -z "$bead_title" ] && bead_title="closed via ralph"

  msg="$bead_id: $bead_title"
  if ! git -C "$repo" add -A; then
    echo "scripts/ralph-loop: 'git add -A' failed for $bead_id" >&2
    current_bead=""
    return 1
  fi
  if ! git -C "$repo" commit -m "$msg" \
    -m "Wrapper-committed by scripts/ralph-loop after agent close. See bd show $bead_id for close reason." \
    >/dev/null; then
    echo "scripts/ralph-loop: 'git commit' failed for $bead_id" >&2
    current_bead=""
    return 1
  fi
  new_head="$(git -C "$repo" rev-parse --short HEAD)"
  echo "scripts/ralph-loop: wrapper-committed $bead_id as $new_head ($msg)" >&2

  current_bead=""
  return 0
}

if [ -n "$requested_bead" ]; then
  run_iteration "$requested_bead"
  exit "$?"
fi

iteration=0
last_bead=""
while [ "$iteration" -lt "$max_iterations" ]; do
  bead_id="$(next_ready_bead)"
  if [ -z "$bead_id" ]; then
    echo "scripts/ralph-loop: no ready non-epic beads remaining; stopping after $iteration iteration(s)" >&2
    bd ready >&2 || true
    exit 0
  fi
  if [ "$bead_id" = "$last_bead" ]; then
    echo "scripts/ralph-loop: bead '$bead_id' is still next-ready after the previous iteration; the agent did not close or block it. Stopping to avoid burning tokens on a stuck bead." >&2
    exit 1
  fi
  iteration=$((iteration + 1))
  echo "scripts/ralph-loop: iteration $iteration/$max_iterations on $bead_id ($agent)" >&2
  run_iteration "$bead_id"
  status=$?
  if [ "$status" -ne 0 ]; then
    exit "$status"
  fi
  last_bead="$bead_id"
done

echo "scripts/ralph-loop: reached RALPH_MAX_ITERATIONS=$max_iterations; stopping" >&2
exit 0
